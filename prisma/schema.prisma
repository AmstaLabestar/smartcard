generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String?       @unique
  phoneNumber  String?       @unique
  passwordHash String
  firstName    String?
  lastName     String?
  role         UserRole      @default(USER)
  cards        Card[]
  offers       Offer[]
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Card {
  id                       String     @id @default(uuid())
  title                    String
  description              String?
  planNameSnapshot         String?
  planDescriptionSnapshot  String?
  planHighlightsSnapshot   String?
  planPriceSnapshot        Decimal?   @db.Decimal(10, 2)
  status                   CardStatus @default(INACTIVE)
  cardNumber               String     @unique
  qrCode                   String     @unique
  activationCode           String     @unique
  purchaseReference        String     @unique
  price                    Decimal    @db.Decimal(10, 2)
  activatedAt              DateTime?
  cardPlanId               String?
  cardPlan                 CardPlan?  @relation(fields: [cardPlanId], references: [id], onDelete: SetNull)
  ownerId                  String
  owner                    User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  transactions             Transaction[]
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
}

model CardPlan {
  id                  String         @id @default(uuid())
  name                String
  slug                String         @unique
  description         String?
  marketingHighlights String?
  price               Decimal        @db.Decimal(10, 2)
  status              CardPlanStatus @default(DRAFT)
  cards               Card[]
  offerLinks          CardPlanOffer[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model CardPlanOffer {
  id         String   @id @default(uuid())
  cardPlanId String
  offerId    String
  cardPlan   CardPlan @relation(fields: [cardPlanId], references: [id], onDelete: Cascade)
  offer      Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([cardPlanId, offerId])
}

model Offer {
  id            String          @id @default(uuid())
  title         String
  description   String?
  status        OfferStatus     @default(DRAFT)
  discountType  DiscountType
  discountValue Decimal         @db.Decimal(10, 2)
  terms         String?
  creatorId     String
  creator       User            @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  cardPlanLinks CardPlanOffer[]
  transactions  Transaction[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Transaction {
  id             String            @id @default(uuid())
  originalAmount Decimal           @db.Decimal(10, 2)
  discountAmount Decimal           @db.Decimal(10, 2)
  amount         Decimal           @db.Decimal(10, 2)
  status         TransactionStatus @default(PENDING)
  userId         String
  cardId         String
  offerId        String?
  reference      String            @unique
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  card           Card              @relation(fields: [cardId], references: [id], onDelete: Cascade)
  offer          Offer?            @relation(fields: [offerId], references: [id], onDelete: SetNull)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

enum UserRole {
  USER
  MERCHANT
  ADMIN
}

enum CardStatus {
  PENDING
  ACTIVE
  INACTIVE
  EXPIRED
  ARCHIVED
}

enum CardPlanStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OfferStatus {
  DRAFT
  ACTIVE
  EXPIRED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}
